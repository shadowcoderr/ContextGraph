{
  "name": "context-graph",
  "version": "0.3.0",
  "description": "A deterministic 'Flight Data Recorder' for web applications that transforms manual exploration into structured, AI-ready intelligence.",
  "main": "dist/cli/index.js",
  "bin": {
    "context-graph": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "dev": "ts-node src/cli/index.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "test": "jest && npx playwright test",
    "test:watch": "jest --watch",
    "test:playwright": "npx playwright test",
    "clean": "rimraf dist"
  },
  "keywords": [
    "web-capture",
    "playwright",
    "automation",
    "testing",
    "ai",
    "cli"
  ],
  "author": "shadowcoderr",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@playwright/test": "^1.40.0",
    "commander": "^11.0.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "inquirer": "^9.2.12",
    "fs-extra": "^11.2.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "typescript": "^5.0.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "prettier": "^3.1.1",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "rimraf": "^5.0.5"
  }
}